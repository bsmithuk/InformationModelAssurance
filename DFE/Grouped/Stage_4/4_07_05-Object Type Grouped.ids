		<ids:specification ifcVersion="IFC2X3" name="4_07_05_DistributionElementType : Type Should Have Name Matching Project Standards" description="Type Should Have Name Matching Project Standards" identifier="4_07_05_DistributionElementType">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<ids:simpleValue>IFCDISTRIBUTIONELEMENTTYPE</ids:simpleValue>
					</ids:name>
				</ids:entity>
			</ids:applicability>
			<ids:requirements>
				<ids:attribute cardinality="required">
					<ids:name>
						<ids:simpleValue>Name</ids:simpleValue>
					</ids:name>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="DistributionElement_(([A-Z][a-z]+)+_)?Type[A-Za-z]{0,3}\d{2,4}" />
						</xs:restriction>
					</ids:value>
				</ids:attribute>
			</ids:requirements>
		</ids:specification>
