			<ids:requirements>
				<ids:attribute cardinality="required">
					<ids:name>
						<ids:simpleValue>Name</ids:simpleValue>
					</ids:name>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:attribute>
				<ids:attribute cardinality="required">
					<ids:name>
						<ids:simpleValue>Description</ids:simpleValue>
					</ids:name>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:attribute>
				<ids:classification cardinality="required">
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="Pr_.*" />
						</xs:restriction>
					</ids:value>
					<ids:system>
						<xs:restriction base="xs:string">
							<xs:pattern value="Uniclass Classification" />
						</xs:restriction>
					</ids:system>
				</ids:classification>
			</ids:requirements>
		</ids:specification>
		<ids:specification ifcVersion="IFC2X3" name="4_07_09-63-Object Type (32 requirements)" description="Object Type Shall Have AssetType Defined, and Shall Have AssetType That Is 'Fixed' or 'Movable', and Shall Have ModelLabel That Is Defined, and Shall Have Manufacturer That Is Defined, and Should Have WarrantyGuarantorParts That Is Defined, and Should Have WarrantyDurationParts That Is Defined, and Should Have WarrantyDurationParts That Is '0.0' Or Is A Valid Duration, and Should Have WarrantyGuarantorLabor That Is Defined, and Should Have WarrantyGuarantorLabor That Is 'n/a' Or An Email Address, and Should Have WarrantyDurationLabor That Is Defined, and Should Have WarrantyDurationLabor That Is '0.0' Or Is A Valid Duration, and Should Have ReplacementCost That Is Defined, and Should Have ReplacementCost That Is 'n/a' Or Is A Replacement Cost For The Product Type, and Should Have ExpectedLife That Is Defined, and Should Have ExpectedLife That Is 'n/a' Or Is A Valid Expected Life For The Product Type, and Should Have WarrantyDescription That Is Defined, and Should Have WarrantyDescription That Is 'n/a' Or A Description Of The Warranty For The Product Type, and Should Have NominalLength That Is Defined, and Should Have NominalWidth That Is Defined, and Should Have NominalHeight That Is Defined, and Should Have ModelReference That Is Defined, and Shall Have Shape That Is Defined, and Should Have Size That Is Defined, and Should Have Color That Is Defined, and Should Have Finish That Is Defined, and Should Have Grade That Is Defined, and Should Have Material That Is Defined, and Should Have Constituents That Is Defined, and Should Have Features That Is Defined, and Should Have AccessibilityPerformance That Is Defined, and Should Have CodePerformance That Is Defined, and Should Have SustainabilityPerformance That Is Defined" instructions="" identifier="4_07_09,4_07_10,4_07_14,4_07_12,4_07_15,4_07_17,4_07_18,4_07_20,4_07_21,4_07_23,4_07_24,4_07_26,4_07_27,4_07_29,4_07_30,4_07_32,4_07_33,4_07_35,4_07_37,4_07_39,4_07_41,4_07_43,4_07_45,4_07_47,4_07_49,4_07_51,4_07_53,4_07_55,4_07_57,4_07_59,4_07_61,4_07_63">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<xs:restriction base="xs:string">
							<xs:enumeration value="IFCDOORSTYLE" />
							<xs:enumeration value="IFCBUILDINGELEMENTPROXYTYPE" />
