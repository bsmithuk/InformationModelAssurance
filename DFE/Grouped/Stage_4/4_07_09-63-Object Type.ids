							<xs:enumeration value="IFCEVAPORATIVECOOLERTYPE" />
							<xs:enumeration value="IFCEVAPORATORTYPE" />
							<xs:enumeration value="IFCHEATEXCHANGERTYPE" />
							<xs:enumeration value="IFCHUMIDIFIERTYPE" />
