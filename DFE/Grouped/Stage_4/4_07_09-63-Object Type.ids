							<xs:enumeration value="IFCWASTETERMINALTYPE" />
							<xs:enumeration value="IFCAIRTERMINALTYPE" />
							<xs:enumeration value="IFCGASTERMINALTYPE" />
							<xs:enumeration value="IFCELECTRICAPPLIANCETYPE" />
							<xs:enumeration value="IFCELECTRICHEATERTYPE" />
