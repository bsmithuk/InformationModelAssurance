			<ids:requirements>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Asset</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>AssetType</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Asset</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>AssetType</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:enumeration value="Fixed" />
							<xs:enumeration value="Movable" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCLABEL">
					<ids:propertySet>
						<ids:simpleValue>Pset_ManufacturerTypeInformation</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>ModelLabel</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCLABEL">
					<ids:propertySet>
						<ids:simpleValue>Pset_ManufacturerTypeInformation</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>Manufacturer</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Warranty</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyGuarantorParts</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Warranty</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyDurationParts</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Warranty</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyDurationParts</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="\d+(\.\d+)?" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Warranty</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyGuarantorLabor</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Warranty</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyGuarantorLabor</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="n\/a|([A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,})" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Warranty</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyDurationLabor</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Warranty</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyDurationLabor</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="\d+(\.\d+)?" />
						</xs:restriction>
					</ids:value>
				</ids:property>
