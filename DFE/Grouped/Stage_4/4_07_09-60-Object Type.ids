			<ids:requirements>
				<ids:attribute cardinality="required">
					<ids:name>
						<ids:simpleValue>Name</ids:simpleValue>
					</ids:name>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:attribute>
				<ids:attribute cardinality="required">
					<ids:name>
						<ids:simpleValue>Description</ids:simpleValue>
					</ids:name>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:attribute>
				<ids:classification cardinality="required">
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="Pr_.*" />
						</xs:restriction>
					</ids:value>
					<ids:system>
						<xs:restriction base="xs:string">
							<xs:pattern value="Uniclass Classification" />
						</xs:restriction>
					</ids:system>
				</ids:classification>
			</ids:requirements>
		</ids:specification>
		<ids:specification ifcVersion="IFC2X3" name="4_07_09-60-Object Type (31 requirements)" description="Object Type Shall Have AssetType Defined, and Shall Have AssetType Matching The Projects Information Standard, and Shall Have Manufacturer That Is Defined, and Shall Have ModelLabel That Is Defined, and Shall Have WarrantyGuarantorParts That Is Defined, and Shall Have WarrantyDurationParts That Is Defined, and Should Have WarrantyDurationParts That Is '0.0' Or Is A Valid Duration, and Shall Have WarrantyGuarantorLabor That Is Defined, and Shall Have WarrantyDurationLabor That Is Defined, and Should Have WarrantyDurationLabor That Is '0.0' Or Is A Valid Duration, and Shall Have ReplacementCost That Is Defined, and Should Have ReplacementCost That Is 'n/a' Or Is A Replacement Cost For The Product Type, and Shall Have ExpectedLife That Is Defined, and Should Have ExpectedLife That Is 'n/a' Or Is A Valid Expected Life For The Product Type, and Shall Have WarrantyDescription That Is Defined, and Should Have WarrantyDescription That Is 'n/a' Or A Description Of The Warranty For The Product Type, and Shall Have NominalLength That Is Defined, and Shall Have NominalWidth That Is Defined, and Shall Have NominalHeight That Is Defined, and Shall Have ModelReference That Is Defined, and Shall Have Shape That Is Defined, and Shall Have Size That Is Defined, and Shall Have Color That Is Defined, and Shall Have Finish That Is Defined, and Shall Have Grade That Is Defined, and Shall Have Material That Is Defined, and Shall Have Constituents That Is Defined, and Shall Have Features That Is Defined, and Shall Have AccessibilityPerformance That Is Defined, and Shall Have CodePerformance That Is Defined, and Shall Have SustainabilityPerformance That Is Defined" instructions="" identifier="4_07_09,4_07_10,4_07_11,4_07_14,4_07_16,4_07_19,4_07_19_02,4_07_21,4_07_24,4_07_24_02,4_07_26,4_07_26_02,4_07_28,4_07_28_02,4_07_30,4_07_30_02,4_07_32,4_07_34,4_07_36,4_07_38,4_07_40,4_07_42,4_07_44,4_07_46,4_07_48,4_07_50,4_07_52,4_07_54,4_07_56,4_07_58,4_07_60">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
