	<ids:specifications>
		<ids:specification ifcVersion="IFC2X3" name="5_08_01-23-Object Occurrence (COBie Component) (18 requirements)" description="Object Occurrence (COBie Component) Object Occurrence Shall Have Name Defined, and Object Occurrence Shall Have Description Defined, and Object Occurrence Shall Have SerialNumber That Is Defined, and Object Occurrence Should Have SerialNumber That Is 'n/a' Or Valid SerialNumber, and Object Occurrence Should Not Have SerialNumber That Is 'n/a', and Object Occurrence Shall Have InstallationDate That Is Defined, and Object Occurrence Should Have InstallationDate That Is '1900-12-31T23:59:59' Or Actual InstallationDate, and Object Occurrence Should Have InstallationDate That Is An Actual Date, and Object Occurrence Shall Have WarrantyStartDate That Is Defined, and Object Occurrence Should Have WarrantyStartDate That Is '1900-12-31T23:59:59' Or Actual WarrantyStartDate, and Object Occurrence Should Have WarrantyStartDate That Is An Actual Date, and Object Occurrence Shall Have TagNumber That Is Defined, and Object Occurrence Should Not Have TagNumber That Is 'n/a', and Object Occurrence Shall Have BarCode That Is Defined, and Object Occurrence Should Have BarCode That Is 'n/a' Or Actual BarCode, and Object Occurrence Should Not Have BarCode That Is 'n/a', and Object Occurrence Shall Have AssetIdentifier That Is Defined, and Object Occurrence Should Not Have AssetIdentifier That Is 'n/a'" instructions="" identifier="5_08_01,5_08_07,5_08_08,5_08_09,5_08_10,5_08_11,5_08_12,5_08_13,5_08_14,5_08_15,5_08_16,5_08_17,5_08_18,5_08_19,5_08_20,5_08_21,5_08_22,5_08_23">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<xs:restriction base="xs:string">
							<xs:enumeration value="IFCBUILDINGELEMENTPROXY" />
							<xs:enumeration value="IFCDOOR" />
							<xs:enumeration value="IFCWINDOW" />
							<xs:enumeration value="IFCFLOWMOVINGDEVICE" />
							<xs:enumeration value="IFCDISTRIBUTIONCONTROLELEMENT" />
							<xs:enumeration value="IFCDISTRIBUTIONCHAMBERELEMENT" />
							<xs:enumeration value="IFCENERGYCONVERSIONDEVICE" />
							<xs:enumeration value="IFCFLOWCONTROLLER" />
							<xs:enumeration value="IFCELECTRICDISTRIBUTIONPOINT" />
							<xs:enumeration value="IFCFLOWMOVINGDEVICE" />
							<xs:enumeration value="IFCFLOWSTORAGEDEVICE" />
							<xs:enumeration value="IFCFLOWTERMINAL" />
							<xs:enumeration value="IFCFLOWTREATMENTDEVICE" />
							<xs:enumeration value="IFCDISCRETEACCESSORY" />
							<xs:enumeration value="IFCTENDON" />
							<xs:enumeration value="IFCFURNISHINGELEMENT" />
							<xs:enumeration value="IFCTRANSPORTELEMENT" />
						</xs:restriction>
					</ids:name>
				</ids:entity>
			</ids:applicability>
			<ids:requirements>
				<ids:attribute cardinality="required">
					<ids:name>
						<ids:simpleValue>Name</ids:simpleValue>
					</ids:name>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:attribute>
				<ids:attribute cardinality="required">
					<ids:name>
						<ids:simpleValue>Description</ids:simpleValue>
					</ids:name>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:attribute>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>Pset_ManufacturerOccurrence</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>SerialNumber</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>Pset_ManufacturerOccurrence</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>SerialNumber</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="n\/a|(\d|-| |_)+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>Pset_ManufacturerOccurrence</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>SerialNumber</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="[^n].*|n([^/].*)?|n\/([^a].*)?|n\/a.+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>InstallationDate</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>InstallationDate</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="1900-12-31T23:59:59(Z|[+-]\d{2}:\d{2})?|20\d{2}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])(?:T(?:[01][0-9]|2[0-3]):(?:[0-5][0-9]):(?:[0-5][0-9])(?:\.\d+)?(?:Z|[+-]\d{2}:\d{2})?)?" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>InstallationDate</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="20\d{2}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])(?:T(?:[01][0-9]|2[0-3]):(?:[0-5][0-9]):(?:[0-5][0-9])(?:\.\d+)?(?:Z|[+-]\d{2}:\d{2})?)?" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyStartDate</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyStartDate</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="1900-12-31T23:59:59(Z|[+-]\d{2}:\d{2})?|20\d{2}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])(?:T(?:[01][0-9]|2[0-3]):(?:[0-5][0-9]):(?:[0-5][0-9])(?:\.\d+)?(?:Z|[+-]\d{2}:\d{2})?)?" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>WarrantyStartDate</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="20\d{2}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])(?:T(?:[01][0-9]|2[0-3]):(?:[0-5][0-9]):(?:[0-5][0-9])(?:\.\d+)?(?:Z|[+-]\d{2}:\d{2})?)?" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>TagNumber</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>TagNumber</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="[^n].*|n([^/].*)?|n\/([^a].*)?|n\/a.+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>Pset_ManufacturerOccurrence</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>BarCode</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>Pset_ManufacturerOccurrence</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>BarCode</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="n\/a|(\d|-| |_)+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>Pset_ManufacturerOccurrence</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>BarCode</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="[^n].*|n([^/].*)?|n\/([^a].*)?|n\/a.+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>AssetIdentifier</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value=".+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCTEXT">
					<ids:propertySet>
						<ids:simpleValue>COBie_Component</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>AssetIdentifier</ids:simpleValue>
					</ids:baseName>
