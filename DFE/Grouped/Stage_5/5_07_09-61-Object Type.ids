		<ids:specification ifcVersion="IFC2X3" name="5_07_09-61-Object Type (58 requirements)" description="Object Type Shall Have AssetType Defined, and Shall Have AssetType Matching The Projects Information Standard, and Shall Have Manufacturer That Is Defined, and Should Not Have Manufacturer That Is 'n/a', and Should Have Manufacturer That Is An Email Address, and Shall Have ModelLabel That Is Defined, and Shall Not Have ModelLabel That Is 'n/a', and Shall Have WarrantyGuarantorParts That Is Defined, and Should Not Have WarrantyGuarantorParts That Is 'n/a' Or Empty, and Should Have WarrantyGuarantorParts That Is An Email Address, and Shall Have WarrantyDurationParts That Is Defined, and Should Have WarrantyDurationParts That Is '0.0' Or Is A Valid Duration, and Should Have WarrantyDurationParts That Is A Valid Non-Zero Duration, and Shall Have WarrantyGuarantorLabor That Is Defined, and Should Not Have WarrantyGuarantorLabor That Is 'n/a' Or Empty, and Should Have WarrantyGuarantorLabor That Is An Email Address, and Shall Have WarrantyDurationLabor That Is Defined, and Should Have WarrantyDurationLabor That Is '0.0' Or Is A Valid Duration, and Should Have WarrantyDurationLabor That Is A Valid Non-Zero Duration, and Shall Have ReplacementCost That Is Defined, and Should Have ReplacementCost That Is 'n/a' Or Is A Replacement Cost For The Product Type, and Should Not Have ReplacementCost That Is 'n/a', and Shall Have ExpectedLife That Is Defined, and Should Have ExpectedLife That Is 'n/a' Or Is A Valid Expected Life For The Product Type, and Should Not Have ExpectedLife That Is 'n/a', and Shall Have WarrantyDescription That Is Defined, and Should Have WarrantyDescription That Is 'n/a' Or A Description Of The Warranty For The Product Type, and Should Not Have WarrantyDescription That Is 'n/a', and Shall Have NominalLength That Is Defined, and Should Have NominalLength That Is A Valid Number, and Shall Have NominalWidth That Is Defined, and Should Have NominalWidth That Is A Valid Number, and Shall Have NominalHeight That Is Defined, and Should Have NominalHeight That Is A Valid Number, and Shall Have ModelReference That Is Defined, and Should Not Have ModelReference That Is 'n/a', and Shall Have Shape That Is Defined, and Should Have Shape That Is Not 'n/a' Or Empty, and Shall Have Size That Is Defined, and Should Not Have Size That Is 'n/a', and Shall Have Color That Is Defined, and Should Not Have Color That Is 'n/a', and Shall Have Finish That Is Defined, and Should Not Have Finish That Is 'n/a', and Shall Have Grade That Is Defined, and Should Not Have Grade That Is 'n/a', and Shall Have Material That Is Defined, and Should Not Have Material That Is 'n/a', and Shall Have Constituents That Is Defined, and Should Not Have Constituents That Is 'n/a', and Shall Have Features That Is Defined, and Should Not Have Features That Is 'n/a', and Shall Have AccessibilityPerformance That Is Defined, and Should Not Have AccessibilityPerformance That Is 'n/a', and Shall Have CodePerformance That Is Defined, and Should Not Have CodePerformance That Is 'n/a', and Shall Have SustainabilityPerformance That Is Defined, and Should Not Have SustainabilityPerformance That Is 'n/a'" instructions="" identifier="5_07_09,5_07_10,5_07_11,5_07_12,5_07_13,5_07_14,5_07_15,5_07_16,5_07_17,5_07_18,5_07_19,5_07_19_02,5_07_20,5_07_21,5_07_22,5_07_23,5_07_24,5_07_24_02,5_07_25,5_07_26,5_07_26_02,5_07_27,5_07_28,5_07_28_02,5_07_29,5_07_30,5_07_30_02,5_07_31,5_07_32,5_07_33,5_07_34,5_07_35,5_07_36,5_07_37,5_07_38,5_07_39,5_07_40,5_07_41,5_07_42,5_07_43,5_07_44,5_07_45,5_07_46,5_07_47,5_07_48,5_07_49,5_07_50,5_07_51,5_07_52,5_07_53,5_07_54,5_07_55,5_07_56,5_07_57,5_07_58,5_07_59,5_07_60,5_07_61">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
