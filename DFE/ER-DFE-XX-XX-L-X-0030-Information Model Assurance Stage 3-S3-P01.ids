		<ids:specification ifcVersion="IFC2X3" name="3_01_07 : Project Shall Have Phase Matching The Projects Information Standard" description="Project Shall Have Phase Matching The Projects Information Standard" identifier="3_01_07">
			<ids:applicability minOccurs="1" maxOccurs="unbounded">
