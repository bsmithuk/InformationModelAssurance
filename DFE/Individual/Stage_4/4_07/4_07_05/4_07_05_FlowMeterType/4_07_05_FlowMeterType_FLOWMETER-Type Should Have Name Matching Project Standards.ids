	<ids:specifications>
		<ids:specification ifcVersion="IFC2X3" name="4_07_05_FlowMeterType_FLOWMETER : Type Should Have Name Matching Project Standards" description="Type Should Have Name Matching Project Standards" identifier="4_07_05_FlowMeterType_FLOWMETER">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<ids:simpleValue>IFCFLOWMETERTYPE</ids:simpleValue>
					</ids:name>
					<ids:predefinedType>
