<?xml version="1.0" encoding="utf-8"?>
<ids:ids xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://standards.buildingsmart.org/IDS http://standards.buildingsmart.org/IDS/1.0/ids.xsd" xmlns:ids="http://standards.buildingsmart.org/IDS">
	<ids:info>
		<ids:title>4_05_14_SL_25_75_76 : Spaces with classification 'S3036, S3037, S3038,+9 more' Should Have Uniclass Classification Classification With Value 'SL_25_75_76'</ids:title>
		<ids:copyright>CC BY 4.0</ids:copyright>
		<ids:version>P01</ids:version>
		<ids:description>Assurance of IFC-SPF deliverables against DfE's S25 Information Requirements - Individual</ids:description>
		<ids:author>DfE.BIM@Education.gov.uk</ids:author>
		<ids:date>2026-05-20</ids:date>
		<ids:purpose>Information Model Assurance</ids:purpose>
		<ids:milestone>RIBA Stage 4 : Technical Design</ids:milestone>
	</ids:info>
	<ids:specifications>
		<ids:specification ifcVersion="IFC2X3" name="4_05_14_SL_25_75_76 : Spaces with classification 'S3036, S3037, S3038,+9 more' Should Have Uniclass Classification Classification With Value 'SL_25_75_76'" description="Spaces with classification 'S3036, S3037, S3038,+9 more' Should Have Uniclass Classification Classification With Value 'SL_25_75_76'" identifier="4_05_14_SL_25_75_76">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<ids:simpleValue>IFCSPACE</ids:simpleValue>
					</ids:name>
				</ids:entity>
				<ids:classification>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:enumeration value="S3036" />
							<xs:enumeration value="S3037" />
							<xs:enumeration value="S3038" />
							<xs:enumeration value="S3039" />
							<xs:enumeration value="S3040" />
							<xs:enumeration value="S3041" />
							<xs:enumeration value="S3042" />
							<xs:enumeration value="S3043" />
							<xs:enumeration value="S3044" />
							<xs:enumeration value="S3045" />
							<xs:enumeration value="S3046" />
							<xs:enumeration value="S3047" />
						</xs:restriction>
					</ids:value>
					<ids:system>
						<xs:restriction base="xs:string">
							<xs:pattern value="DfE Space Classification" />
						</xs:restriction>
					</ids:system>
				</ids:classification>
			</ids:applicability>
			<ids:requirements>
				<ids:classification cardinality="required">
					<ids:value>
						<ids:simpleValue>SL_25_75_76</ids:simpleValue>
					</ids:value>
					<ids:system>
						<xs:restriction base="xs:string">
							<xs:enumeration value="Uniclass Classification" />
						</xs:restriction>
					</ids:system>
				</ids:classification>
			</ids:requirements>
		</ids:specification>
	</ids:specifications>
</ids:ids>