	<ids:specifications>
		<ids:specification ifcVersion="IFC2X3" name="3_05_15_SL_90_10_15 : Spaces with classification 'S7002, S7005, S7010,+16 more' Should Have Uniclass Classification Classification With Value 'SL_90_10_15'" description="Spaces with classification 'S7002, S7005, S7010,+16 more' Should Have Uniclass Classification Classification With Value 'SL_90_10_15'" identifier="3_05_15_SL_90_10_15">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<ids:simpleValue>IFCSPACE</ids:simpleValue>
					</ids:name>
				</ids:entity>
				<ids:classification>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:enumeration value="S7002" />
							<xs:enumeration value="S7005" />
