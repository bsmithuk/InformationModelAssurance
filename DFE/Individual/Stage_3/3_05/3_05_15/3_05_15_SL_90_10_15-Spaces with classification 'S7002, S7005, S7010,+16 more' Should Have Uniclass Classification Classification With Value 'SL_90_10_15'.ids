							<xs:enumeration value="S7052" />
							<xs:enumeration value="S7053" />
							<xs:enumeration value="S7054" />
							<xs:enumeration value="S7055" />
							<xs:enumeration value="S7057" />
							<xs:enumeration value="S7059" />
							<xs:enumeration value="S7076" />
							<xs:enumeration value="S7110" />
							<xs:enumeration value="S7111" />
							<xs:enumeration value="S7112" />
						</xs:restriction>
					</ids:value>
					<ids:system>
