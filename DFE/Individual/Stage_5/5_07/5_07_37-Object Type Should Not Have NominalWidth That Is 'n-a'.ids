							<xs:enumeration value="IFCVALVETYPE" />
							<xs:enumeration value="IFCELECTRICTIMECONTROLTYPE" />
							<xs:enumeration value="IFCPROTECTIVEDEVICETYPE" />
							<xs:enumeration value="IFCSWITCHINGDEVICETYPE" />
							<xs:enumeration value="IFCCOMPRESSORTYPE" />
							<xs:enumeration value="IFCFANTYPE" />
							<xs:enumeration value="IFCPUMPTYPE" />
							<xs:enumeration value="IFCTANKTYPE" />
							<xs:enumeration value="IFCELECTRICFLOWSTORAGEDEVICETYPE" />
							<xs:enumeration value="IFCFIRESUPPRESSIONTERMINALTYPE" />
							<xs:enumeration value="IFCSANITARYTERMINALTYPE" />
