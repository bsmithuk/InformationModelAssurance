		<ids:date>2026-05-20</ids:date>
		<ids:purpose>Information Model Assurance</ids:purpose>
		<ids:milestone>RIBA Stage 5 : Construction and Manufacturing</ids:milestone>
	</ids:info>
	<ids:specifications>
		<ids:specification ifcVersion="IFC2X3" name="5_07_37 : Object Type Should Not Have NominalWidth That Is 'n/a'" description="Object Type Should Not Have NominalWidth That Is 'n/a'" identifier="5_07_37">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<xs:restriction base="xs:string">
							<xs:enumeration value="IFCDOORSTYLE" />
							<xs:enumeration value="IFCBUILDINGELEMENTPROXYTYPE" />
							<xs:enumeration value="IFCWINDOWSTYLE" />
							<xs:enumeration value="IFCACTUATORTYPE" />
