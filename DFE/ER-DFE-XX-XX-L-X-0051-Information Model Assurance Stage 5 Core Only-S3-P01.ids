		<ids:specification ifcVersion="IFC2X3" name="5_03_06 : Building Shall Have Uniclass Classification Defined" description="Building Shall Have Uniclass Classification Defined" identifier="5_03_06">
			<ids:applicability minOccurs="1" maxOccurs="unbounded">
